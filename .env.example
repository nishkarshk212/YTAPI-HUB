# ─── Local ───────────────────────────────────────────────
DATABASE_URL="postgresql://ytapi:ytapi_secret@localhost:5432/ytapi_hub?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
APP_NAME="YTAPI Hub"

# ─── Split deployment (recommended) ─────────────────────
# Website (Vercel): dashboard, docs, auth, admin UI
# API (Render):     public REST API at /api/v1

# Vercel env vars:
# NEXTAUTH_URL=https://your-app.vercel.app
# NEXTAUTH_SECRET=same-secret-on-both-platforms
# DATABASE_URL=postgresql://... (shared — use Render Postgres external URL or Neon)
# NEXT_PUBLIC_API_BASE_URL=https://ytapi-hub-api.onrender.com/api/v1
# API_BASE_URL=https://ytapi-hub-api.onrender.com/api/v1

# Render env vars (set after first deploy):
# NEXTAUTH_URL=https://ytapi-hub-api.onrender.com
# API_BASE_URL=https://ytapi-hub-api.onrender.com/api/v1
# DATABASE_URL=(auto from Render Postgres via render.yaml)

# Optional
CORS_ORIGINS="*"
ADMIN_EMAIL="admin@ytapi.dev"
ADMIN_PASSWORD="admin123456"
